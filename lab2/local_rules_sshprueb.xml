<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  ============================================================
  REGLA PERSONALIZADA: BRUTE FORCE SSH DETECTION
  ============================================================
  Autor: Fray Kana Chullo (IX Ciclo - Ingenieria de Sistemas)
  Fecha: 2026-06-30
  Descripcion: Detecta ataques de fuerza bruta SSH mediante
               analisis de frecuencia de fallos de autenticacion.
  ID Base: 5712 (SSH failed authentication)
  ============================================================
-->

<group name="local,ssh,authentication_failures,brute_force,">

    <!--
      REGLA PRINCIPAL DE BRUTE FORCE
      Detecta 10 o mas fallos de autenticacion SSH desde la misma IP
      en un intervalo de 60 segundos
    -->
    <rule id="100001" level="10" frequency="10" timeframe="60">
        <if_matched_sid>5712</if_matched_sid>
        <same_source_ip/>
        <description>Ataque de fuerza bruta SSH detectado desde $(srcip)</description>
        <group>authentication_failures,brute_force</group>
    </rule>

    <!--
      REGLA DE ALERTA TEMPRANA
      Detecta 5 fallos en 30 segundos como pre-alerta
    -->
    <rule id="100002" level="7" frequency="5" timeframe="30">
        <if_matched_sid>5712</if_matched_sid>
        <same_source_ip/>
        <description>Posible ataque de fuerza bruta SSH desde $(srcip) - Actividad sospechosa temprana</description>
        <group>authentication_failures,brute_force,pre_alert</group>
    </rule>

    <!--
      REGLA DE RESPUESTA ACTIVA
      Nivel critico para activar contramedidas automaticas
    -->
    <rule id="100003" level="12" frequency="20" timeframe="120">
        <if_matched_sid>5712</if_matched_sid>
        <same_source_ip/>
        <description>ATAQUE BRUTE FORCE SSH PERSISTENTE desde $(srcip) - Accion automatica requerida</description>
        <group>authentication_failures,brute_force,critical</group>
    </rule>

</group>