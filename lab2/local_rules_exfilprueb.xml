<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  ============================================================
  REGLAS PERSONALIZADAS: EXFILTRACION DE DATOS Y ANOMALIAS
  ============================================================
  Autor: Fray Kana Chullo (IX Ciclo - Ingenieria de Sistemas)
  Fecha: 2026-06-30
  Descripcion: Detecta patrones de exfiltracion de datos y
               actividades anomales en el trafico de red.
  ============================================================
-->

<group name="local,exfiltration,data_loss,anomaly,">

    <!--
      REGLA 1: EXFILTRACION POR VOLUMEN DE DATOS
      Detecta trafico saliente superior a 500 MB en una conexion
    -->
    <rule id="100004" level="14">
        <if_sid>1004</if_sid>
        <match>bytes_sent > 524288000</match>
        <description>Posible exfiltracion de datos: Trafico saliente masivo (>500MB) detectado desde $(srcip) hacia $(dstip)</description>
        <group>exfiltration,data_loss,high_volume</group>
    </rule>

    <!--
      REGLA 2: EXFILTRACION + LOGIN FUERA DE HORARIO
      Correlacion de actividad de exfiltracion con logins fuera de horario
    -->
    <rule id="100005" level="15">
        <if_sid>100004</if_sid>
        <if_matched_sid>1002</if_matched_sid>
        <same_src_ip/>
        <time>22:00-06:00</time>
        <description>EXFILTRACION CRITICA: Transferencia masiva de datos en horario no laboral desde $(srcip) - Posible robo de informacion</description>
        <group>exfiltration,data_loss,critical,out_of_hours</group>
    </rule>

    <!--
      REGLA 3: PATRONES DE EXFILTRACION WEB
      Detecta patrones sospechosos en URLs (SQLi, LFI, RFI)
    -->
    <rule id="100006" level="12">
        <if_sid>31101</if_sid>
        <regex>(\b(UNION|SELECT|FROM|WHERE|INSERT|DELETE|UPDATE|DROP|EXEC|EXECUTE)\b|\.\./|\.\.\\|base64_decode|eval\(|\$_GET|\$_POST|system\(|exec\(|passthru\()</regex>
        <description>Posible ataque de exfiltracion Web detectado: $(url) desde $(srcip)</description>
        <group>web_attack,exfiltration,sqli,lfi,rfi</group>
    </rule>

    <!--
      REGLA 4: ANOMALIA DE PUERTOS DE EXFILTRACION
      Detecta trafico saliente hacia puertos atipicos (exfiltracion comun)
    -->
    <rule id="100007" level="11">
        <if_sid>1004</if_sid>
        <match>dst_port = 21|22|53|80|443|1433|3306|3389|5900|8080|8443|10443</match>
        <description>Trafico saliente hacia puerto sospechoso desde $(srcip):$(srcport) hacia $(dstip):$(dstport) - Posible canal de exfiltracion</description>
        <group>exfiltration,suspicious_port,data_leak</group>
    </rule>

</group>