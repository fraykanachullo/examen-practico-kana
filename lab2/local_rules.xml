<!-- Local rules -->
<!-- Modified by Fray Kana Chullo - Lab 2 - 2026-06-30 -->

<group name="local,syslog,sshd,authentication_failures,brute_force,">

  <!-- Regla existente del sistema -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- REGLA DE FUERZA BRUTA SSH CORRECTA -->
  <rule id="100010" level="10" frequency="10" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip/>
    <description>Ataque de fuerza bruta SSH detectado desde $(srcip)</description>
    <group>authentication_failures,brute_force</group>
  </rule>

</group>
